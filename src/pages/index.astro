---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Built by Dana — UI Developer & Redesign Specialist"
  description="Dana is a UI developer with agency ecommerce experience and self-taught design skills, now available for freelance UI development and redesign projects."
>

  <!-- ===================== HERO ===================== -->
  <section class="hero" id="home" aria-label="Hero">
    <div class="hero__inner">
      <div class="hero__tag">
        <span class="hero__tag-dot" aria-hidden="true"></span>
        Available for work
      </div>
      <h1 class="hero__headline">
        Interfaces<br>
        people actually<br>
        <em>want</em> to use.
      </h1>
      <p class="hero__sub">
        I'm Dana — a UI developer with agency ecommerce experience and self-taught design skills.
        I can take a project from Figma or Sketch all the way through to a built, responsive interface.
      </p>
      <div class="hero__actions">
        <a href="#work" class="btn btn--primary">See my work</a>
        <a href="#contact" class="btn btn--ghost">Get in touch</a>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span>scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ===================== TICKER ===================== -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__track">
      <span class="ticker__item">UI Design</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Ecommerce</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Wireframing</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Visual Refresh</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">App Redesign</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Figma</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Sketch</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Web Design</span>
      <span class="ticker__sep">✦</span>
      <!-- Duplicate for seamless infinite loop -->
      <span class="ticker__item">UI Design</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Ecommerce</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Wireframing</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Visual Refresh</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">App Redesign</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Figma</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Sketch</span>
      <span class="ticker__sep">✦</span>
      <span class="ticker__item">Web Design</span>
      <span class="ticker__sep">✦</span>
    </div>
  </div>

  <!-- ===================== ABOUT ===================== -->
  <section class="about section" id="about" aria-label="About">
    <div class="container">
      <div class="about__grid">

        <div class="about__image-wrap fade-in">
          <!-- Replace this div with an <img> tag when you have a photo -->
          <div class="about__photo-placeholder" role="img" aria-label="Photo of Dana">
            <div class="about__photo-gradient"></div>
            <span class="about__photo-initial" aria-hidden="true">D</span>
          </div>
          <div class="about__badge" aria-label="Currently open to projects">
            <span class="about__badge-dot" aria-hidden="true"></span>
            Open to projects
          </div>
        </div>

        <div class="about__content fade-in">
          <p class="section-label">About me</p>
          <h2 class="about__heading">
            I build the things<br>designers hand off.
          </h2>
          <p class="about__text">
            I spent years as a UI developer at a digital agency, building interfaces for
            ecommerce clients — product pages, checkout flows, landing pages, and everything
            in between. I've implemented enough designs to know what works in the browser,
            what developers actually need, and where design decisions create problems down
            the line.
          </p>
          <p class="about__text">
            Along the way I taught myself Figma and Sketch, so I can now handle both sides.
            I'm stepping into freelance for the first time — offering UI development, redesign,
            and design-to-code work for clients who want one person who understands the full picture.
          </p>
          <div class="about__tools" aria-label="Tools I use">
            <span>Figma</span>
            <span>Sketch</span>
            <span>FigJam</span>
            <span>Notion</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="services section" id="services" aria-label="Services">
    <div class="container">
      <div class="services__header fade-in">
        <p class="section-label">What I do</p>
        <h2 class="services__heading">How I can help you</h2>
      </div>
      <div class="services__grid">

        <article class="service-card fade-in">
          <div class="service-card__number" aria-hidden="true">01</div>
          <h3 class="service-card__title">Frontend Implementation</h3>
          <p class="service-card__desc">
            My core skill. I translate designs into clean, responsive HTML and CSS that
            actually match the mockup — no guesswork, no back-and-forth. Ideal for teams who
            need a developer who can read a Figma or Sketch file fluently.
          </p>
          <ul class="service-card__list">
            <li>HTML &amp; CSS build-out</li>
            <li>Responsive &amp; mobile-first layouts</li>
            <li>Figma &amp; Sketch to code</li>
            <li>UI polish &amp; pixel refinement</li>
            <li>Ecommerce page builds</li>
          </ul>
        </article>

        <article class="service-card fade-in">
          <div class="service-card__number" aria-hidden="true">02</div>
          <h3 class="service-card__title">Redesign &amp; Refresh</h3>
          <p class="service-card__desc">
            Got a page that's not converting, or an interface that just feels dated? I'll
            review what's not working and rebuild it — then implement it myself if needed,
            no handoff required.
          </p>
          <ul class="service-card__list">
            <li>Usability &amp; layout review</li>
            <li>Conversion-focused redesign</li>
            <li>Visual refresh &amp; modernization</li>
            <li>Mobile-first optimization</li>
            <li>Ecommerce page redesign</li>
          </ul>
        </article>

        <article class="service-card fade-in">
          <div class="service-card__number" aria-hidden="true">03</div>
          <h3 class="service-card__title">UI Design</h3>
          <p class="service-card__desc">
            Self-taught in Figma and Sketch, I can put together wireframes and high-fidelity
            mockups for smaller scopes — particularly useful when you need design and build
            handled by the same person.
          </p>
          <ul class="service-card__list">
            <li>Wireframing &amp; layout</li>
            <li>High-fidelity mockups</li>
            <li>Figma &amp; Sketch files</li>
            <li>Mobile-first design</li>
            <li>Design-to-code delivery</li>
          </ul>
        </article>

      </div>
    </div>
  </section>

  <!-- ===================== WORK ===================== -->
  <section class="work section" id="work" aria-label="Selected work">
    <div class="container">
      <div class="work__header fade-in">
        <p class="section-label">Selected work</p>
        <h2 class="work__heading">Agency work &amp; projects</h2>
      </div>
      <div class="work__grid">

        <article class="work-card fade-in">
          <div class="work-card__image work-card__image--1">
            <div class="work-card__overlay">
              <span>Coming soon</span>
            </div>
          </div>
          <div class="work-card__info">
            <span class="work-card__tag">App Redesign</span>
            <h3 class="work-card__title">Project coming soon</h3>
          </div>
        </article>

        <article class="work-card fade-in">
          <div class="work-card__image work-card__image--2">
            <div class="work-card__overlay">
              <span>Coming soon</span>
            </div>
          </div>
          <div class="work-card__info">
            <span class="work-card__tag">UI Development</span>
            <h3 class="work-card__title">Project coming soon</h3>
          </div>
        </article>

        <article class="work-card work-card--wide fade-in">
          <div class="work-card__image work-card__image--3">
            <div class="work-card__overlay">
              <span>Coming soon</span>
            </div>
          </div>
          <div class="work-card__info">
            <span class="work-card__tag">Frontend Build</span>
            <h3 class="work-card__title">Project coming soon</h3>
          </div>
        </article>

      </div>
      <p class="work__note fade-in">
        My work is from agency projects — case studies and samples available on request.
        <a href="#contact">Get in touch to see more →</a>
      </p>
    </div>
  </section>

  <!-- ===================== CONTACT ===================== -->
  <section class="contact section" id="contact" aria-label="Contact">
    <div class="container">
      <div class="contact__inner fade-in">
        <p class="section-label">Get in touch</p>
        <h2 class="contact__heading">
          Got a project in mind?<br>
          <span>Let's build it.</span>
        </h2>
        <p class="contact__sub">
          I'm new to freelancing but not to the work — I've built real interfaces for real
          ecommerce clients. If you need a developer who can also handle the design side,
          let's see if I'm the right fit.
        </p>

        <form
          class="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/success"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="visually-hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message">What do you need?</label>
            <textarea id="message" name="message" placeholder="Tell me about your project..." required></textarea>
          </div>
          <button type="submit" class="btn btn--primary contact-form__submit">Send message</button>
        </form>

        <p class="contact__alt">
          Or email directly:
          <a href="mailto:hello@builtbydana.com" class="contact__email">hello@builtbydana.com</a>
        </p>

        <nav class="contact__links" aria-label="Social links">
          <!-- Update these href values with your actual profile URLs -->
          <a href="#" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="#" target="_blank" rel="noopener noreferrer">Dribbble</a>
          <a href="#" target="_blank" rel="noopener noreferrer">Read.cv</a>
        </nav>
      </div>
    </div>
  </section>

</Layout>
