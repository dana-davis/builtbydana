---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message sent — Built by Dana"
  description="Your message has been received. Dana will be in touch soon."
>

  <section class="success-page section" aria-label="Message sent">
    <div class="container">
      <div class="success-page__inner">
        <div class="success-page__icon" aria-hidden="true">✦</div>
        <h1 class="success-page__heading">Message received.</h1>
        <p class="success-page__text">
          Thanks for reaching out — I'll get back to you soon.
        </p>
        <a href="/" class="btn btn--primary">Back to home</a>
      </div>
    </div>
  </section>

</Layout>
